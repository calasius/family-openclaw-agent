{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "env": {
    "vars": {
      "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
      "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}",
      "AGENT_WATCH_TELEGRAM_BOT_TOKEN": "${AGENT_WATCH_TELEGRAM_BOT_TOKEN}"
    }
  },
  "browser": {
    "headless": true,
    "noSandbox": true,
    "executablePath": "/opt/ms-playwright/chromium-1217/chrome-linux64/chrome",
    "extraArgs": ["--disable-gpu", "--disable-dev-shm-usage"],
    "profiles": {
      "user": {
        "cdpPort": 18801,
        "color": "#00AA00"
      },
      "host": {
        "cdpPort": 18802,
        "color": "#FF4500"
      }
    }
  },
  "plugins": {
    "load": {
      "paths": [
        "/home/node/.openclaw/extensions/school-guardian-tools",
        "/app/extensions/browser"
      ]
    },
    "allow": ["school-guardian-tools", "browser"],
    "entries": {
      "school-guardian-tools": {
        "enabled": true
      },
      "browser": {
        "enabled": true
      }
    }
  },
  "tools": {
    "allow": [
      "school_guardian_skill_log",
      "school_guardian_web_search",
      "agent_watch_fetch",
      "agent_watch_send",
      "agent_watch_topics",
      "agent_watch_search",
      "agent_watch_topic",
      "agent_watch_item_detail",
      "school_guardian_ping",
      "school_guardian_sync",
      "school_guardian_list_pending",
      "school_guardian_list_subjects",
      "school_guardian_list_subjects_cli",
      "school_guardian_daily_focus",
      "school_guardian_task_detail",
      "school_guardian_export_solution",
      "browser"
    ],
    "deny": ["nodes"]
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspaces",
      "model": {
        "primary": "openai-codex/gpt-5.4"
      }
    },
    "list": [
      {
        "id": "school-guardian",
        "workspace": "/home/node/.openclaw/workspaces/school-guardian",
        "tools": {
          "allow": [
            "school_guardian_skill_log",
            "school_guardian_web_search",
            "agent_watch_fetch",
            "agent_watch_send",
            "agent_watch_topics",
            "agent_watch_search",
            "agent_watch_topic",
            "agent_watch_item_detail",
            "school_guardian_ping",
            "school_guardian_sync",
            "school_guardian_list_pending",
            "school_guardian_list_subjects",
            "school_guardian_list_subjects_cli",
            "school_guardian_daily_focus",
            "school_guardian_task_detail",
            "school_guardian_export_solution",
            "browser"
          ],
          "deny": ["nodes"]
        }
      },
      {
        "id": "agent-watch",
        "workspace": "/home/node/.openclaw/workspaces/agent-watch",
        "tools": {
          "allow": [
            "agent_watch_fetch",
            "agent_watch_send",
            "agent_watch_topics",
            "agent_watch_search",
            "agent_watch_topic",
            "agent_watch_item_detail"
          ],
          "deny": ["nodes", "browser"]
        }
      }
    ]
  },
  "bindings": [
    {
      "match": {
        "channel": "telegram",
        "accountId": "agentwatch"
      },
      "agentId": "agent-watch"
    },
    {
      "match": {
        "channel": "telegram",
        "accountId": "default"
      },
      "agentId": "school-guardian"
    }
  ],
  "channels": {
    "telegram": {
      "enabled": true,
      "defaultAccount": "default",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "8687277701",
        "8616681320",
        "8582567139"
      ],
      "accounts": {
        "default": {
          "name": "School Guardian",
          "botToken": "${TELEGRAM_BOT_TOKEN}"
        },
        "agentwatch": {
          "name": "Agent Watch",
          "dmPolicy": "open",
          "allowFrom": ["*"],
          "botToken": "${AGENT_WATCH_TELEGRAM_BOT_TOKEN}"
        }
      },
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  }
}
