{
  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
    auth: {
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
  },

  identity: {
    name: "School Guardian",
    theme: "asistente escolar por Telegram para una estudiante",
  },

  env: {
    vars: {
      OPENROUTER_API_KEY: "${OPENROUTER_API_KEY}",
      TELEGRAM_BOT_TOKEN: "${TELEGRAM_BOT_TOKEN}",
      AGENT_WATCH_TELEGRAM_BOT_TOKEN: "${AGENT_WATCH_TELEGRAM_BOT_TOKEN}",
    },
  },

  agents: {
    defaults: {
      workspace: "/workspace",
      model: {
        primary: "openai-codex/gpt-5.4",
      },
    },
    list: [
      {
        id: "family-orchestrator",
      },
      {
        id: "school-guardian",
      },
      {
        id: "agent-watch",
      },
    ],
  },

  bindings: [
    {
      match: {
        channel: "telegram",
        accountId: "agentwatch",
      },
      agentId: "agent-watch",
    },
    {
      match: {
        channel: "telegram",
        accountId: "default",
      },
      agentId: "school-guardian",
    },
  ],

  channels: {
    telegram: {
      enabled: true,
      defaultAccount: "default",
      dmPolicy: "allowlist",
      allowFrom: ["${TELEGRAM_ALLOWED_FROM}"],
      accounts: {
        default: {
          name: "School Guardian",
          botToken: "${TELEGRAM_BOT_TOKEN}",
        },
        agentwatch: {
          name: "Agent Watch",
          dmPolicy: "open",
          allowFrom: ["*"],
          botToken: "${AGENT_WATCH_TELEGRAM_BOT_TOKEN}",
        },
      },
      groups: {
        "*": {
          requireMention: true,
        },
      },
    },
  },
}
